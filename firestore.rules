rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && request.auth.token.email is string
        && request.auth.token.email_verified == true
        && request.auth.token.email == "aistech@aisociety.io";
    }

    function isOwnerByEmail() {
      return isSignedIn()
        && request.auth.token.email is string
        && resource.data.email is string
        && resource.data.email == request.auth.token.email;
    }

    function ownerCanUpdateSelfFieldsOnly() {
      return isOwnerByEmail()
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          "fname",
          "lname",
          "hasLoggedIn",
          "phone_number",
          "updatedAt",
        ])
        && (
          !("fname" in request.resource.data.diff(resource.data).changedKeys())
          || request.resource.data.fname is string
        )
        && (
          !("lname" in request.resource.data.diff(resource.data).changedKeys())
          || request.resource.data.lname is string
        )
        && (
          !("hasLoggedIn" in request.resource.data)
          || request.resource.data.hasLoggedIn == true
        )
        && (
          !("phone_number" in request.resource.data)
          || request.resource.data.phone_number is string
        );
    }

    function isPublicSignupCodeLookup(hackerId) {
      return request.auth == null
        && hackerId.matches('^[0-9]{6}$')
        && (
          (resource.data.access_code is string && resource.data.access_code == hackerId)
          || (resource.data.accessCode is string && resource.data.accessCode == hackerId)
        );
    }

    match /schedule/{doc} {
      allow read: if true;
      allow write: if false;
    }

    match /faqs/{doc} {
      allow read: if true;
      allow write: if false;
    }

    match /donors/{doc} {
      allow read: if true;
      allow write: if false;
    }

    match /sponsors/{doc} {
      allow read: if true;
      allow write: if false;
    }

    match /tracks/{doc} {
      allow read: if true;
      allow write: if false;
    }

    match /keynote/{doc} {
      allow read: if true;
      allow write: if false;
    }

    match /hackers/{hackerId} {
      // Signed-in users can read any hacker doc (needed for unique-code generation).
      allow get: if isAdmin() || isOwnerByEmail() || isPublicSignupCodeLookup(hackerId) || isSignedIn();

      // Admin can list all. Signed-in users can only match docs where doc email == auth email.
      allow list: if isAdmin() || isOwnerByEmail();

      // Admin can create freely. Signed-in users can create their own doc (email must match auth).
      allow create: if isAdmin()
        || (isSignedIn()
            && request.resource.data.email is string
            && request.resource.data.email == request.auth.token.email);

      // Admin can update all fields; users can only set allowed self-service fields.
      allow update: if isAdmin() || ownerCanUpdateSelfFieldsOnly();

      allow delete: if isAdmin();
    }

    match /hackers/{hackerId}/scans/{scanId} {
      allow get, list, create, update, delete: if isAdmin();
    }

    match /scannerStats/{docId} {
      allow get, list, create, update: if isAdmin();
      allow delete: if false;
    }

    // Deny anything not explicitly allowed above.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
